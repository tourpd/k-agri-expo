"use client";

import React from "react";

export type HallHotspot = {
  hallId: string;
  title: string;
  subtitle: string;
  color: string;

  // ✅ 핫스팟 위치(%) — 지도 이미지 위에 올릴 버튼 박스
  // left/top/width/height 는 0~100 (퍼센트)
  box: { left: number; top: number; width: number; height: number };
};

export default function ExpoMapClient({ halls }: { halls: HallHotspot[] }) {
  const containerRef = React.useRef<HTMLDivElement | null>(null);
  const [scale, setScale] = React.useState(1);
  const [pos, setPos] = React.useState({ x: 0, y: 0 });
  const [dragging, setDragging] = React.useState(false);
  const startRef = React.useRef<{ x: number; y: number; px: number; py: number } | null>(null);

  function clamp(n: number, min: number, max: number) {
    return Math.max(min, Math.min(max, n));
  }

  function onWheel(e: React.WheelEvent) {
    // ✅ 트랙패드/휠 확대
    if (!e.ctrlKey && Math.abs(e.deltaY) < 2) return; // 너무 미세한 움직임 방지
    e.preventDefault();
    const next = clamp(scale + (e.deltaY > 0 ? -0.08 : 0.08), 1, 2.4);
    setScale(next);
  }

  function onPointerDown(e: React.PointerEvent) {
    // ✅ 드래그 이동
    setDragging(true);
    (e.currentTarget as HTMLElement).setPointerCapture(e.pointerId);
    startRef.current = { x: e.clientX, y: e.clientY, px: pos.x, py: pos.y };
  }

  function onPointerMove(e: React.PointerEvent) {
    if (!dragging || !startRef.current) return;
    const dx = e.clientX - startRef.current.x;
    const dy = e.clientY - startRef.current.y;
    setPos({ x: startRef.current.px + dx, y: startRef.current.py + dy });
  }

  function onPointerUp() {
    setDragging(false);
    startRef.current = null;
  }

  function zoomIn() {
    setScale((s) => clamp(s + 0.15, 1, 2.4));
  }
  function zoomOut() {
    setScale((s) => clamp(s - 0.15, 1, 2.4));
  }
  function reset() {
    setScale(1);
    setPos({ x: 0, y: 0 });
  }

  return (
    <div>
      {/* ✅ 툴바(모바일 큰 버튼) */}
      <div style={toolbar}>
        <div style={{ fontWeight: 950, fontSize: 16 }}>전시장 지도</div>
        <div style={{ display: "flex", gap: 10 }}>
          <button type="button" onClick={zoomOut} style={toolBtn} aria-label="축소">
            −
          </button>
          <button type="button" onClick={zoomIn} style={toolBtn} aria-label="확대">
            +
          </button>
          <button type="button" onClick={reset} style={toolBtnWide} aria-label="초기화">
            초기화
          </button>
        </div>
      </div>

      {/* ✅ 지도 영역 */}
      <div
        ref={containerRef}
        style={stage}
        onWheel={onWheel}
        onPointerDown={onPointerDown}
        onPointerMove={onPointerMove}
        onPointerUp={onPointerUp}
      >
        {/* ✅ “지도” 배경(우선은 가상 지도 느낌 / 나중에 실제 박람회 지도 이미지로 교체) */}
        <div
          style={{
            ...map,
            transform: `translate(${pos.x}px, ${pos.y}px) scale(${scale})`,
            cursor: dragging ? "grabbing" : "grab",
          }}
        >
          {/* 배경(가상 박람회장) */}
          <div style={mapBg}>
            <div style={mapTitle}>K-Agri Expo 전시장</div>
            <div style={mapHint}>전시관을 터치해서 입장하십시오</div>

            {/* “도로/구역” 같은 시각 요소(가볍게) */}
            <div style={roadH} />
            <div style={roadV} />
            <div style={plaza}>중앙 광장</div>
          </div>

          {/* ✅ 핫스팟 버튼들 */}
          {halls.map((h) => (
            <a
              key={h.hallId}
              href={`/expo/hall/${h.hallId}`}
              style={{
                ...hotspot,
                left: `${h.box.left}%`,
                top: `${h.box.top}%`,
                width: `${h.box.width}%`,
                height: `${h.box.height}%`,
                borderColor: h.color,
              }}
            >
              <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
                <span style={{ ...hotDot, background: h.color }} />
                <div style={{ display: "flex", flexDirection: "column" }}>
                  <div style={hotTitle}>{h.title}</div>
                  <div style={hotSub}>{h.subtitle}</div>
                </div>
              </div>
              <div style={enterPill}>입장</div>
            </a>
          ))}
        </div>
      </div>

      <div style={tip}>
        ✅ 지도를 <b>드래그</b>로 이동 / <b>+ −</b>로 확대·축소 가능합니다.
      </div>
    </div>
  );
}

