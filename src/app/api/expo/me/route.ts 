import { NextResponse } from "next/server";
import { cookies } from "next/headers";
import { createSupabaseServerClient } from "@/lib/supabase/server";

export const dynamic = "force-dynamic";

export async function GET() {
  const cookieStore = await cookies();
  const visitor_key = cookieStore.get("visitor_key")?.value;

  if (!visitor_key) {
    return NextResponse.json({ ok: false, error: "NO_VISITOR" }, { status: 401 });
  }

  const supabase = await createSupabaseServerClient();

  const { data, error } = await supabase
    .from("expo_visitors")
    .select("id,name,phone,region,main_crop")
    .eq("visitor_key", visitor_key)
    .maybeSingle();

  if (error) {
    return NextResponse.json({ ok: false, error: error.message }, { status: 500 });
  }
  if (!data) {
    return NextResponse.json({ ok: false, error: "VISITOR_NOT_FOUND" }, { status: 401 });
  }

  // last_seen_at 갱신(실패해도 무시)
  await supabase
    .from("expo_visitors")
    .update({ last_seen_at: new Date().toISOString() })
    .eq("id", data.id);

  return NextResponse.json({ ok: true, visitor: data });
}